# Discord Configuration
DISCORD_PUBLIC_KEY=your-discord-public-key-here
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Claude API Configuration (optional)
# Get your API key from https://console.anthropic.com/account/keys
# If not provided, captures will be marked but not summarized
CLAUDE_API_KEY=sk-ant-your-api-key-here

# DynamoDB Tables
CAPTURES_TABLE=discord-ops-captures
REMINDERS_TABLE=discord-ops-reminders
EXPORTS_TABLE=discord-ops-exports

# SQS Queues (for local testing with sam local)
TASKS_QUEUE_URL=http://localhost:9324/000000000000/discord-ops-tasks

# S3 Bucket for exports
EXPORTS_BUCKET=discord-ops-exports-123456789

# AWS Region
AWS_REGION=us-east-1
AWS_PROFILE=default
